# ─── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_PRICE_ID=your-stripe-price-id-here            # 2500 HUF product price ID
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here

# ─── Cloudflare Stream ─────────────────────────────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id-here
CF_STREAM_ID=your-cloudflare-stream-id-here                     # Live Input or Video ID
CF_STREAM_KEY_ID=your-cloudflare-stream-key-id-here             # Signing key ID from CF dashboard
CF_STREAM_PRIVATE_KEY=your-cloudflare-stream-private-key-here   # RSA private key for JWT signing (PEM, base64)

# ─── Database (pick one) ───────────────────────────────────────
DATABASE_URL=your-database-connection-string-here

# ─── Supabase (if using Supabase Auth) ─────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
